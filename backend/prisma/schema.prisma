generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int        @id @default(autoincrement())
  email         String     @unique
  passwordHash  String
  // Allowed values: CANDIDATE, EMPLOYER, ADMIN
  role          String
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  candidate     Candidate?
  employer      Employer?
  notifications Notification[]

  @@index([role])
}

model Candidate {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName      String
  headline      String?
  bio           String?
  phone         String?
  location      String?
  profilePic    String?
  resumeUrl     String?
  websiteUrl    String?
  linkedinUrl   String?
  githubUrl     String?

  educations    Education[]
  experiences   Experience[]
  certifications Certification[]
  candidateSkills CandidateSkill[]
  applications  Application[]
  savedJobs     SavedJob[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([location])
}

model Employer {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String
  jobTitle    String?
  phone       String?

  companyId   Int?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  postedJobs  Job[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Company {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  website     String?
  logoUrl     String?
  industry    String?
  size        String?
  location    String?

  employers   Employer[]
  jobs        Job[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([name])
  @@index([industry])
}

model Skill {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique

  candidateSkills CandidateSkill[]
  jobSkills       JobSkill[]
}

model CandidateSkill {
  candidateId Int
  skillId     Int
  level       String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
  @@index([skillId])
}

model JobSkill {
  jobId     Int
  skillId   Int
  required  Boolean @default(true)
  job       Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@index([skillId])
}

model Education {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  school      String
  degree      String?
  fieldOfStudy String?
  startDate   DateTime?
  endDate     DateTime?
  description String?
}

model Experience {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company     String
  title       String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?
}

model Certification {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  issuer      String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  credentialUrl String?
}

model Job {
  id              Int             @id @default(autoincrement())
  title           String
  slug            String          @unique
  description     String
  category        String?
  location        String?
  // Allowed values: REMOTE, ONSITE, HYBRID
  jobMode         String          @default("ONSITE")
  // Allowed values: FULL_TIME, PART_TIME, CONTRACT, INTERNSHIP, TEMPORARY
  jobType         String          @default("FULL_TIME")
  // Allowed values: ENTRY, JUNIOR, MID, SENIOR, LEAD, EXECUTIVE
  experienceLevel String          @default("MID")
  salaryMin       Int?
  salaryMax       Int?
  currency        String          @default("USD")
  // Allowed values: DRAFT, PUBLISHED, CLOSED, REMOVED
  status          String          @default("PUBLISHED")
  applicationDeadline DateTime?

  companyId       Int
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedById      Int
  postedBy        Employer        @relation(fields: [postedById], references: [id], onDelete: Cascade)

  jobSkills       JobSkill[]
  applications    Application[]
  savedBy         SavedJob[]

  views           Int             @default(0)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([title])
  @@index([location])
  @@index([category])
  @@index([status])
  @@index([jobMode])
  @@index([jobType])
  @@index([experienceLevel])
}

model Application {
  id          Int       @id @default(autoincrement())
  jobId       Int
  candidateId Int
  // Allowed values: APPLIED, UNDER_REVIEW, INTERVIEW, REJECTED, HIRED, WITHDRAWN
  status      String    @default("APPLIED")
  coverLetter String?
  resumeUrl   String?
  notes       String?

  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([jobId, candidateId])
  @@index([status])
}

model SavedJob {
  candidateId Int
  jobId       Int
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  savedAt     DateTime  @default(now())

  @@id([candidateId, jobId])
  @@index([jobId])
}

model Notification {
  id        Int               @id @default(autoincrement())
  userId    Int
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Allowed values: APPLICATION_UPDATE, NEW_MATCHING_JOB, INTERVIEW_INVITE, SYSTEM
  type      String
  title     String
  message   String
  link      String?
  read      Boolean           @default(false)
  createdAt DateTime          @default(now())

  @@index([userId, read])
}
