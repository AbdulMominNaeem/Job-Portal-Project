# MySQL connection
DATABASE_URL="mysql://jobportal:jobportal@localhost:3306/jobportal"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS
CLIENT_ORIGIN="http://localhost:5173"

# Uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# Rate limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300
